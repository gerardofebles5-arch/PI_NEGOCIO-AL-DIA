# --- Autenticación ---
# Secreto para firmar las sesiones (JWT). Cambia esto en producción.
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio

# Correos que tendrán rol ADMIN (separados por coma).
ADMIN_EMAILS=gerardofebles5@gmail.com,gfebles@negocioaldia.app

# Minutos que dura válido el código de verificación.
VERIFICATION_CODE_TTL_MINUTES=15

# --- Envío de correos (verificación de cuenta) ---
# 100% gratis con un Gmail + "contraseña de aplicación":
#   https://myaccount.google.com/apppasswords
# Si dejas esto vacío, el código se imprime en los logs (solo desarrollo).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-contrasena-de-aplicacion
# Remitente mostrado (por defecto usa SMTP_USER).
SMTP_FROM=
# STARTTLS en el puerto 587 (true) o SSL en el 465 (false).
SMTP_USE_TLS=true

# --- Base de datos y almacenamiento ---
DATABASE_URL=sqlite:///./data/pinad.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25

# --- CORS ---
# "*" permite todos los orígenes. En producción pon tu dominio.
CORS_ORIGINS=*
