# --- Autenticación ---
# Client ID de Google OAuth (tipo "Web application"). Es público y gratuito.
GOOGLE_CLIENT_ID=

# Secreto para firmar las sesiones (JWT). Cambia esto en producción.
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio

# Permitir login de desarrollo (sin Google). Pon false en producción.
ALLOW_DEV_LOGIN=true

# Correos que tendrán rol ADMIN (separados por coma).
ADMIN_EMAILS=gerardofebles5@gmail.com,gfebles@negocioaldia.app

# --- Base de datos y almacenamiento ---
DATABASE_URL=sqlite:///./data/pinad.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25

# --- CORS ---
# "*" permite todos los orígenes. En producción pon tu dominio.
CORS_ORIGINS=*
