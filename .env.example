# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=config/service_account.json

# Database Configuration
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:pinad-db
DB_USER=pinad_user
DB_PASSWORD=your_db_password
DB_NAME=pinad_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://pinad_user:your_db_password@localhost:5432/pinad_db

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# OAuth2 Configuration
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:5000/callback

# Google Services
FORMS_CREDENTIALS_PATH=config/service_account.json
SHEETS_CREDENTIALS_PATH=config/service_account.json
SHEETS_ID=your-spreadsheet-id
DRIVE_CREDENTIALS_PATH=config/service_account.json
DRIVE_FOLDER_ID=your-drive-folder-id

# Document AI
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# API Configuration
API_BASE_URL=http://localhost:5000
API_VERSION=v1
API_KEY=your-api-key
SECRET_KEY=your-secret-key-here

# Multi-Tenancy
DEFAULT_ISOLATION_LEVEL=shared_database
ENABLE_TENANT_CACHE=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pinad.log

# Environment
ENVIRONMENT=development
DEBUG=true
